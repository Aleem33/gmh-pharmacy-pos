{
  "name": "gmh-pharmacy-pos",
  "productName": "GMH Pharmacy POS",
  "private": true,
  "version": "1.1.6",
  "description": "GMH Pharmacy Point of Sale System",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "build:android": "VITE_TARGET=android vite build",
    "build:android:win": "set VITE_TARGET=android&& vite build",
    "cap:sync": "npm run build:android && npx cap sync android",
    "cap:sync:win": "npm run build:android:win && npx cap sync android"
  },
  "build": {
    "appId": "com.gmh.pharmacypos",
    "productName": "GMH Pharmacy POS",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "icon.ico",
      "icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GMH Pharmacy POS",
      "installerIcon": "icon.ico"
    },
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Aleem33",
        "repo": "gmh-pharmacy-pos",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "electron-updater": "^6.3.9",
    "react-is": "^18.3.1",
    "@capacitor/core": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/share": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@capacitor/cli": "^7.0.0"
  }
}